PORT=5000
NODE_ENV=development

MONGO_URI=mongodb://root:secret@localhost:27017

# Sign key for JWT — use a long random string in production
JWT_SECRET=change_me

# Comma-separated allowed CORS origins. Omit to reflect any origin (dev only).
CORS_ORIGIN=http://localhost:5173

# Admin seeding (run once: node src/seed/admin.seed.js)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
